{
  "id": "claw-router",
  "name": "Claw Router — Smart Model Routing",
  "version": "2.0.0",
  "description": "Intelligent model routing plugin for OpenClaw — routes messages to optimal AI models based on trait-based capability matching",
  "author": "aiwaretop",
  "license": "AIWare Community License",
  "repository": {
    "type": "git",
    "url": "https://github.com/HackSing/claw-router.git"
  },
  "entry": "index.ts",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "models": {
        "type": "array",
        "description": "模型能力声明列表。每个模型通过 traits 描述擅长的领域和复杂度等级。",
        "items": {
          "type": "object",
          "properties": {
            "id": {
              "type": "string",
              "description": "模型标识，如 anthropic/claude-sonnet"
            },
            "traits": {
              "type": "array",
              "description": "能力特征列表。Tier: TRIVIAL/SIMPLE/MODERATE/COMPLEX/EXPERT; TaskType: coding/writing/chat/analysis/translation/math/research/other",
              "items": {
                "type": "string"
              }
            }
          },
          "required": [
            "id",
            "traits"
          ]
        }
      },
      "thresholds": {
        "type": "array",
        "description": "四个评分分界点 [trivial→simple, simple→moderate, moderate→complex, complex→expert]",
        "items": {
          "type": "number"
        },
        "minItems": 4,
        "maxItems": 4
      },
      "scoring": {
        "type": "object",
        "properties": {
          "weights": {
            "type": "object",
            "description": "覆盖维度权重"
          }
        }
      },
      "logging": {
        "type": "boolean",
        "description": "启用详细路由日志",
        "default": false
      },
      "enableSemanticRouting": {
        "type": "boolean",
        "description": "启用基于本地嵌入模型的语义路由（默认关闭，开启后首次使用会下载语义模型）",
        "default": false
      },
      "llmScoring": {
        "type": "object",
        "description": "LLM 辅助评分配置。规则评分处于 tier 边界时触发，同时用于多模型冲突仲裁。",
        "properties": {
          "enabled": {
            "type": "boolean",
            "description": "启用 LLM 辅助",
            "default": false
          },
          "model": {
            "type": "string",
            "description": "LLM 模型（如 deepseek-ai/DeepSeek-V3-Chat）"
          },
          "apiKey": {
            "type": "string",
            "description": "LLM 提供商 API Key"
          },
          "baseUrl": {
            "type": "string",
            "description": "LLM API 基础 URL"
          },
          "apiPath": {
            "type": "string",
            "description": "API 端点路径（默认 /v1/chat/completions）"
          }
        }
      }
    }
  }
}
