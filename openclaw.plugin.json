{
  "id": "claw-router",
  "name": "Claw Router — Smart Model Routing",
  "version": "1.1.0",
  "description": "Intelligent model routing plugin for OpenClaw — routes messages to optimal AI models based on 8-dimension complexity scoring",
  "author": "aiwaretop",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/HackSing/claw-router.git"
  },
  "entry": "index.ts",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "tiers": {
        "type": "object",
        "description": "Per-tier model mapping. Keys: TRIVIAL, SIMPLE, MODERATE, COMPLEX, EXPERT"
      },
      "thresholds": {
        "type": "array",
        "description": "Four score boundaries [trivial→simple, simple→moderate, moderate→complex, complex→expert]",
        "items": {
          "type": "number"
        },
        "minItems": 4,
        "maxItems": 4
      },
      "scoring": {
        "type": "object",
        "properties": {
          "weights": {
            "type": "object",
            "description": "Override dimension weights"
          }
        }
      },
      "logging": {
        "type": "boolean",
        "description": "Enable verbose routing logs",
        "default": false
      },
      "llmScoring": {
        "type": "object",
        "description": "LLM-based scoring configuration. Only triggers when rule-based score is near tier boundaries (±0.08).",
        "properties": {
          "enabled": {
            "type": "boolean",
            "description": "Enable LLM-enhanced scoring",
            "default": false
          },
          "model": {
            "type": "string",
            "description": "LLM model for scoring (e.g., deepseek-ai/DeepSeek-V3-Chat)"
          },
          "apiKey": {
            "type": "string",
            "description": "API key for LLM provider"
          },
          "baseUrl": {
            "type": "string",
            "description": "Base URL for LLM API"
          },
          "apiPath": {
            "type": "string",
            "description": "API endpoint path (default: /v1/chat/completions)"
          }
        }
      }
    }
  }
}